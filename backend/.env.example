# RouterAI
ROUTERAI_API_KEY=your_routerai_key_here
ROUTERAI_BASE_URL=https://routerai.ru/api/v1
ROUTERAI_MODEL=qwen/qwen3-max

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/soviet_chat

# CORS
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com

# Yandex SpeechKit TTS
# Получить: https://console.yandex.cloud/ → IAM → Сервисные аккаунты
# Роль сервисного аккаунта: ai.speechkit.tts
YANDEX_API_KEY=your_yandex_api_key_here
YANDEX_FOLDER_ID=your_folder_id_here
